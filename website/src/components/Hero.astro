---

---

<section
  class="min-h-screen flex flex-col justify-center items-center text-center px-4 relative overflow-hidden bg-background"
  data-reveal
>
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/15 rounded-full blur-[140px] -z-10"
  >
  </div>

  <div
    class="mb-6 inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full text-[11px] font-bold tracking-widest uppercase border border-primary/20 bg-primary/5 text-primary"
  >
    Codeforces Dark
  </div>

  <h1
    class="text-white text-4xl md:text-6xl font-black mb-8 max-w-3xl leading-tight tracking-tight selection:bg-primary/20 uppercase"
  >
    Dark Theme<br />
    <span class="text-primary">for Codeforces.</span>
  </h1>

  <p
    class="text-lg md:text-xl text-body max-w-xl mb-12 leading-relaxed font-medium"
  >
    A simple, high-performance dark theme for Codeforces. Clean interface,
    improved focus, and easy to use.
  </p>

  <div
    class="flex flex-col sm:flex-row gap-4 relative z-10 w-full justify-center"
  >
    <a
      href="#install"
      class="inline-flex items-center justify-center bg-primary text-white font-extrabold py-3.5 px-10 rounded-xl transition-all duration-300 hover:scale-[1.02] active:scale-95 text-xs uppercase tracking-widest"
    >
      Install Extension
    </a>
    <a
      href="https://github.com/developerHub01/CF_Dark"
      target="_blank"
      class="inline-flex items-center justify-center bg-secondary/50 text-white font-bold py-3.5 px-10 border border-white/10 rounded-xl transition-all duration-300 hover:bg-white/5 active:scale-95 text-xs uppercase tracking-widest select-none"
    >
      View GitHub
    </a>
  </div>
</section>
