---
// Footer.astro - Premium High-End Footer
---

<footer
  class="bg-background py-32 border-t border-border relative overflow-hidden"
>
  <div class="container mx-auto max-w-6xl px-4 relative z-10 text-center">
    <!-- Brand Group -->
    <div class="mb-16">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div
          class="w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_15px_rgba(59,130,246,0.6)] animate-pulse"
        >
        </div>
        <span
          class="text-white font-black text-3xl tracking-tighter uppercase selection:bg-primary/20"
          >CF_Dark</span
        >
      </div>
      <p
        class="text-body text-lg max-w-lg mx-auto leading-relaxed font-medium mb-12"
      >
        The definitive dark mode for Codeforces. <br />
        Built for those who code through the night.
      </p>

      <!-- Social Links -->
      <div class="flex justify-center gap-8">
        <a
          target="_blank"
          href="https://github.com/developerHub01"
          class="group text-muted hover:text-primary transition-all duration-300 hover:scale-110"
        >
          <i class="ph ph-github-logo text-3xl"></i>
        </a>
        <a
          target="_blank"
          href="https://shakil102043.vercel.app/"
          class="group text-muted hover:text-primary transition-all duration-300 hover:scale-110"
        >
          <i class="ph ph-globe text-3xl"></i>
        </a>
      </div>
    </div>

    <!-- Bottom Meta Line -->
    <div
      class="w-full border-t border-border pt-16 flex flex-col md:flex-row justify-center items-center gap-10 text-center text-[11px] font-bold uppercase tracking-[0.25em] text-muted"
    >
      <p>© 2026 CF_Dark</p>
    </div>
  </div>
</footer>
